{
  "$defs": {
    "Contradiction": {
      "additionalProperties": false,
      "description": "Contradictory evidence requiring resolution before final authorization.",
      "properties": {
        "conflicting_evidence": {
          "items": {
            "$ref": "#/$defs/EvidenceReference"
          },
          "minItems": 2,
          "title": "Conflicting Evidence",
          "type": "array"
        },
        "contradiction_id": {
          "minLength": 1,
          "title": "Contradiction Id",
          "type": "string"
        },
        "issue": {
          "minLength": 1,
          "title": "Issue",
          "type": "string"
        },
        "requires_human_confirmation": {
          "default": true,
          "title": "Requires Human Confirmation",
          "type": "boolean"
        },
        "status": {
          "default": "unresolved",
          "enum": [
            "unresolved",
            "resolved",
            "dismissed"
          ],
          "title": "Status",
          "type": "string"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "contradiction_id",
        "issue",
        "conflicting_evidence",
        "summary"
      ],
      "title": "Contradiction",
      "type": "object"
    },
    "EvidenceReference": {
      "additionalProperties": false,
      "description": "Source-level pointer used by findings, decisions, and recommendations.",
      "properties": {
        "excerpt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Excerpt"
        },
        "locator": {
          "minLength": 1,
          "title": "Locator",
          "type": "string"
        },
        "record_id": {
          "minLength": 1,
          "title": "Record Id",
          "type": "string"
        },
        "source_file": {
          "minLength": 1,
          "title": "Source File",
          "type": "string"
        }
      },
      "required": [
        "record_id",
        "source_file",
        "locator"
      ],
      "title": "EvidenceReference",
      "type": "object"
    }
  },
  "$id": "project-recovery-council.human-decision-request.v1",
  "additionalProperties": false,
  "description": "Blocking request for human confirmation or approval.",
  "properties": {
    "blocking": {
      "default": true,
      "title": "Blocking",
      "type": "boolean"
    },
    "case_id": {
      "minLength": 1,
      "title": "Case Id",
      "type": "string"
    },
    "contradictions": {
      "items": {
        "$ref": "#/$defs/Contradiction"
      },
      "title": "Contradictions",
      "type": "array"
    },
    "decision_request_id": {
      "minLength": 1,
      "title": "Decision Request Id",
      "type": "string"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/EvidenceReference"
      },
      "title": "Evidence",
      "type": "array"
    },
    "question": {
      "minLength": 1,
      "title": "Question",
      "type": "string"
    },
    "reason": {
      "minLength": 1,
      "title": "Reason",
      "type": "string"
    },
    "requested_by": {
      "minLength": 1,
      "title": "Requested By",
      "type": "string"
    },
    "status": {
      "default": "pending",
      "enum": [
        "pending",
        "answered",
        "cancelled"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "required": [
    "decision_request_id",
    "case_id",
    "reason",
    "question",
    "requested_by"
  ],
  "title": "HumanDecisionRequest",
  "type": "object",
  "x-schema-version": "v1"
}
