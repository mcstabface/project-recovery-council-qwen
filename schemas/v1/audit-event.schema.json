          "title": "Locator",
          "type": "string"
        },
        "record_id": {
          "minLength": 1,
          "title": "Record Id",
          "type": "string"
        },
        "source_file": {
          "minLength": 1,
          "title": "Source File",
          "type": "string"
        }
      },
      "required": [
        "record_id",
        "source_file",
        "locator"
      ],
      "title": "EvidenceReference",
      "type": "object"
    }
  },
  "$id": "project-recovery-council.audit-event.v1",
  "additionalProperties": false,
  "description": "Append-only event for preserving case and orchestration history.",
  "properties": {
    "action": {
      "minLength": 1,
      "title": "Action",
      "type": "string"
    },
