{
  "$defs": {
    "ConfidenceAssessment": {
      "additionalProperties": false,
      "description": "Explicit confidence summary for a conclusion.",
      "properties": {
        "evidence": {
          "items": {
            "$ref": "#/$defs/EvidenceReference"
          },
          "title": "Evidence",
          "type": "array"
        },
        "level": {
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "title": "Level",
          "type": "string"
        },
        "rationale": {
          "minLength": 1,
          "title": "Rationale",
          "type": "string"
        },
        "score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        }
      },
      "required": [
        "level",
        "score",
        "rationale"
      ],
      "title": "ConfidenceAssessment",
      "type": "object"
    },
    "EvidenceReference": {
      "additionalProperties": false,
      "description": "Source-level pointer used by findings, decisions, and recommendations.",
      "properties": {
        "excerpt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Excerpt"
        },
        "locator": {
          "minLength": 1,
          "title": "Locator",
          "type": "string"
        },
        "record_id": {
          "minLength": 1,
          "title": "Record Id",
          "type": "string"
        },
        "source_file": {
          "minLength": 1,
          "title": "Source File",
          "type": "string"
        }
      },
      "required": [
        "record_id",
        "source_file",
        "locator"
      ],
      "title": "EvidenceReference",
      "type": "object"
    },
    "ExpertStatus": {
      "enum": [
        "pending",
        "completed",
        "incomplete",
        "abstained",
        "failed"
      ],
      "title": "ExpertStatus",
      "type": "string"
    }
  },
  "$id": "project-recovery-council.expert-finding.v1",
  "additionalProperties": false,
  "description": "Specialist conclusion or explicit non-conclusion.",
  "properties": {
    "assumptions": {
      "items": {
        "type": "string"
      },
      "title": "Assumptions",
      "type": "array"
    },
    "conclusion": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Conclusion"
    },
    "confidence": {
      "anyOf": [
        {
          "$ref": "#/$defs/ConfidenceAssessment"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/EvidenceReference"
      },
      "title": "Evidence",
      "type": "array"
    },
    "expert_role": {
      "minLength": 1,
      "title": "Expert Role",
      "type": "string"
    },
    "failure_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Failure Reason"
    },
    "finding_id": {
      "minLength": 1,
      "title": "Finding Id",
      "type": "string"
    },
    "incomplete_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Incomplete Reason"
    },
    "request_id": {
      "minLength": 1,
      "title": "Request Id",
      "type": "string"
    },
    "retry_count": {
      "default": 0,
      "minimum": 0,
      "title": "Retry Count",
      "type": "integer"
    },
    "status": {
      "$ref": "#/$defs/ExpertStatus"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "finding_id",
    "request_id",
    "expert_role",
    "status"
  ],
  "title": "ExpertFinding",
  "type": "object",
  "x-schema-version": "v1"
}
