{
  "$defs": {
    "EvidenceReference": {
      "additionalProperties": false,
      "description": "Source-level pointer used by findings, decisions, and recommendations.",
      "properties": {
        "excerpt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Excerpt"
        },
        "locator": {
          "minLength": 1,
          "title": "Locator",
          "type": "string"
        },
        "record_id": {
          "minLength": 1,
          "title": "Record Id",
          "type": "string"
        },
        "source_file": {
          "minLength": 1,
          "title": "Source File",
          "type": "string"
        }
      },
      "required": [
        "record_id",
        "source_file",
        "locator"
      ],
      "title": "EvidenceReference",
      "type": "object"
    }
  },
  "$id": "project-recovery-council.human-decision.v1",
  "additionalProperties": false,
  "description": "Human answer or approval recorded in the case history.",
  "properties": {
    "decided_at": {
      "format": "date-time",
      "title": "Decided At",
      "type": "string"
    },
    "decided_by": {
      "minLength": 1,
      "title": "Decided By",
      "type": "string"
    },
    "decision_id": {
      "minLength": 1,
      "title": "Decision Id",
      "type": "string"
    },
    "decision_request_id": {
      "minLength": 1,
      "title": "Decision Request Id",
      "type": "string"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/EvidenceReference"
      },
      "title": "Evidence",
      "type": "array"
    },
    "outcome": {
      "enum": [
        "approved",
        "rejected",
        "confirmed",
        "unable_to_confirm"
      ],
      "title": "Outcome",
      "type": "string"
    },
    "rationale": {
      "minLength": 1,
      "title": "Rationale",
      "type": "string"
    }
  },
  "required": [
    "decision_id",
    "decision_request_id",
    "outcome",
    "rationale",
    "decided_by",
    "decided_at"
  ],
  "title": "HumanDecision",
  "type": "object",
  "x-schema-version": "v1"
}
